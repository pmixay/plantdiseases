<?xml version="1.0" encoding="utf-8"?>
<!--
    Cleartext HTTP is permitted for ALL hosts so the user can point the
    app at any server IP (LAN, VPN, remote dev box) from Profile →
    Server URL without editing this file. This trades off encrypted-by-
    default transport for flexibility — acceptable for this self-hosted
    app. Switch the base-config to cleartextTrafficPermitted="false" and
    put HTTPS in front of the server when going to production.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
